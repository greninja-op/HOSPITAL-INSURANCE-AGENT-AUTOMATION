# AuthPilot — environment variables (TITLES ONLY; fill in real values in .env, never commit .env)
# Copy to `.env` and populate. `lib/config.ts` validates these on boot (fail-fast).

# ─── Core LLM (required) ─────────────────────────────────────────────────────
# Qwen via Alibaba DashScope (compatible-mode) or OpenRouter as a fallback host.
QWEN_API_KEY=
QWEN_API_BASE=            # e.g. https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_ATTEMPT_TIMEOUT_MS=30000
QWEN_MODEL=qwen-plus      # Chat model for reasoning + international-language translation

# ─── Database (required) ─────────────────────────────────────────────────────
# PostgreSQL. Bring up the local instance with `docker compose up -d postgres`.
# To target another Prisma-supported engine, point DATABASE_URL at it (no code change).
DATABASE_URL=postgresql://authpilot:authpilot@localhost:5433/authpilot

# ─── Diagnosis-code lookup (optional; degrades gracefully) ───────────────────
NIH_CLINICAL_TABLES_BASE=https://clinicaltables.nlm.nih.gov/api/icd10cm/v3/search

# ─── WhatsApp channel (optional; all-or-nothing) ─────────────────────────────
# Leave all blank to run without the WhatsApp channel. If you set any, set all four.
WHATSAPP_TOKEN=                    # Meta Cloud API access token (Bearer)
WHATSAPP_PHONE_NUMBER_ID=          # WhatsApp Business phone number id
WHATSAPP_APP_SECRET=               # Meta app secret — verifies X-Hub-Signature-256
WHATSAPP_VERIFY_TOKEN=             # Arbitrary token for the GET verification handshake
WHATSAPP_API_VERSION=v23.0
WHATSAPP_REENGAGEMENT_TEMPLATE=    # Approved template name for 24h-window fallback
WHATSAPP_STAFF_NUMBERS=            # Comma-separated E.164 numbers allowed to approve/reject

# ─── Multilingual language layer (Sarvam AI; optional) ───────────────────────
# When SARVAM_API_KEY is set, the WhatsApp channel detects the patient's language,
# translates inbound text to English for the pipeline, and localizes generic outbound
# replies back into the patient's language. Indian languages + English are handled by
# Sarvam; international languages (Spanish, French, German, Portuguese, Italian, Dutch,
# Russian, Arabic, Turkish, Chinese, Japanese, Korean, Vietnamese, Indonesian, Polish,
# Thai) are translated by the Qwen model above. Leave SARVAM_API_KEY blank to run
# English-only.
SARVAM_API_KEY=                    # Sarvam API subscription key (api-subscription-key header)
SARVAM_API_BASE=https://api.sarvam.ai
SARVAM_STT_MODEL=saarika:v2.5      # Speech-to-text model (voice notes)
SARVAM_TTS_MODEL=bulbul:v3         # Text-to-speech model (spoken replies)
SARVAM_TTS_SPEAKER=anushka         # TTS speaker voice
SARVAM_TTS_MAX_CHARS=2500          # Truncate long replies before synthesis
TTS_ENABLED=false                  # Set true to send spoken replies to voice-note senders

# ─── App / server ────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ─── Voice channel ───────────────────────────────────────────────────────────
# The demo uses transcript intake only (no real-time media bridge), so no keys are
# required. A full voice bridge would be a separate optional service (see README).
